# Copy this file to .env and fill in the values for your machine.
# .env is gitignored and never committed.

# Path to the local directory containing MUSE data cubes
MUSE_DATA_DIR=/path/to/muse_data

# Base URL for the R21 source catalogue
R21_CAT_URL=https://cral-perso.univ-lyon1.fr/labo/perso/johan.richard/MUSE_data_release/

# Base URL for the R21 pre-extracted spectra
R21_SPEC_URL=https://cral-perso.univ-lyon1.fr/labo/perso/johan.richard/MUSE_Cubes/

# Path to the project root — so matplotlib picks up matplotlibrc automatically
MPLCONFIGDIR=/path/to/MUSE_LAE_pipeline
